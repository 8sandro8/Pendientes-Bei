# Pendientes Bei - Variables de Entorno
# Copia este archivo a .env y completa los valores

# Puerto del servidor
PORT=5017

# Clave secreta para JWT (cámbiala por una segura)
SECRET_KEY=tu_clave_secreta_aqui

# Contraseña de administrador
ADMIN_PASSWORD=tu_contraseña_admin

# Credenciales de email (Gmail)
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_app_gmail
